rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /equipment/{id} {
      allow read, write: if true;
    }
    match /notifications/{id} {
      allow read, write: if true;
    }
    match /performanceStats/{id} {
      allow read, write: if true;
    }
    match /users/{id} {
      allow read, write: if true;
    }
    match /departments/{id} {
      allow read, write: if true;
    }
  }
}
